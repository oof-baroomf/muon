{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*"]
    },
    "outDir": ".webpack",
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "forge.config.ts"]
}
