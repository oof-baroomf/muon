    "tailwindcss": "^3",
    "postcss": "^8",
    "autoprefixer": "^10"
  },
  "dependencies": {
    "@use-gesture/react": "^10",
    "react": "^18",
    "react-dom": "^18",
    "react-draggable": "^4"
  }
}
